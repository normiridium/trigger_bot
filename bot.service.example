[Unit]
Description=Trigger Admin Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=<service_user>
WorkingDirectory=<project_dir>
EnvironmentFile=<project_dir>/.env
ExecStart=<project_dir>/trigger_admin_bot
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
