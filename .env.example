MEDIA_DOWNLOAD_TIMEOUT_SEC=500
COUB_MEDIA_DOWNLOAD_TIMEOUT_SEC=600
COUB_LOOP_SECONDS=0
MEDIA_PROGRESS_MIN_EDIT_INTERVAL_MS=2000
TELEGRAM_SEND_RETRY_ATTEMPTS=3
TELEGRAM_SEND_RETRY_MAX_SEC=120
MEDIA_PROGRESS_BAR_LEFT=<tg-emoji emoji-id="6190572316343144337">◀️</tg-emoji>
MEDIA_PROGRESS_BAR_RUN=<tg-emoji emoji-id="6192818283591242169">⏯</tg-emoji>
MEDIA_PROGRESS_BAR_FILL=<tg-emoji emoji-id="6190533137651469695">⏹</tg-emoji>
MEDIA_PROGRESS_BAR_IDLE=<tg-emoji emoji-id="6197267096615784923">⏩</tg-emoji>
MEDIA_PROGRESS_BAR_END_IDLE=<tg-emoji emoji-id="6197315938983874282">#️⃣</tg-emoji>
MEDIA_PROGRESS_BAR_END_DONE=<tg-emoji emoji-id="6192944714543534133">⏭</tg-emoji>
YTDLP_BIN=
YTDLP_EXTRACTOR_ARGS=youtube:player_client=android,web
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=
FIXIE_SOCKS_HOST=
TRIGGER_BOT_TMP_DIR=/home/appuser/trigger_admin_bot/var/tmp
TRIGGER_BOT_TMP_CLEAN_ON_START=true
TRIGGER_BOT_TMP_MAX_AGE_SEC=86400
VOICE_TRANSCRIPTION_ENABLED=false
VOICE_TRANSLATE_PROVIDER=
