USER_DAILY_BOT_MESSAGES_LIMIT=12
GPT_LINK_CONTEXT_ENABLED=true
GPT_LINK_CONTEXT_MAX_URLS=2
GPT_LINK_CONTEXT_MAX_CHARS=3000
GPT_HUMAN_PAUSE=true
GPT_HUMAN_PAUSE_MIN_MS=1800
GPT_HUMAN_PAUSE_MAX_MS=12000
GPT_HUMAN_PAUSE_LOG=false
GPT_REPLY_REACTION_CHANCE_PERCENT=50
GPT_EDIT_WAIT_SEC=7
GPT_EDIT_WAIT_MAX_SEC=15
GPT_MARKDOWN_DIVIDER_EMOJI=<tg-emoji emoji-id="5213083123218147891">〰️</tg-emoji>
