TELEGRAM_BOT_TOKEN=
# If set, MongoDB is used as primary storage backend.
# Example: mongodb://127.0.0.1:27017/trigger_admin_bot
MONGO_URI=
BOT_DB_FILE=/home/faline/trigger_admin_bot/trigger_bot.db
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
SERPAPI_KEY=
SERPAPI_ENGINE=google_images
VK_TOKEN=
VK_USER_AGENT=

# comma/space-separated numeric chat IDs.
# if empty, bot can work in any chat.
ALLOWED_CHAT_IDS=

# cache admin status lookups for this many seconds (reduces Telegram API calls)
ADMIN_CACHE_TTL_SEC=120

# debug logs (can noticeably slow bot on busy chats if enabled)
DEBUG_TRIGGER_LOG=false
DEBUG_GPT_LOG=false
CHAT_ERROR_LOG=true
WEB_TEMPLATE_DIR=/home/faline/trigger_admin_bot/templates
GPT_PROMPT_DEBOUNCE_SEC=10

# web admin
ADMIN_ENABLED=true
ADMIN_BIND=:8090
ADMIN_TOKEN=
