BOT_COMMANDS_SYNC_INTERVAL_MIN=0
BOT_COMMANDS_LANGS=ru
TRIGGER_ACTION_WORKERS=8
TRIGGER_ACTION_QUEUE=256
TELEGRAM_DROP_PENDING_UPDATES_ON_START=true
TELEGRAM_STARTUP_OLD_UPDATE_GRACE_SEC=0
