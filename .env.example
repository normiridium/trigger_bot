TELEGRAM_BOT_TOKEN=
# If set, MongoDB is used as primary storage backend.
# Example: mongodb://127.0.0.1:27017/trigger_admin_bot
MONGO_URI=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
SERPAPI_KEY=
SERPAPI_ENGINE=google_images
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
YA_MUSIC_TOKEN=
YANDEX_MUSIC_QUALITY=1
YANDEX_MUSIC_TIMEOUT_SEC=45
YANDEX_MUSIC_TRIES=6
YANDEX_MUSIC_RETRY_DELAY_SEC=2
YANDEX_MUSIC_FORCE_MP3=true
YANDEX_MUSIC_EMBED_LYRICS=true
YANDEX_MUSIC_LYRICS_LANG=eng
YANDEX_MUSIC_FFMPEG_BIN=ffmpeg
YANDEX_MUSIC_WORKERS=1
YANDEX_MUSIC_QUEUE=4
SPOTIFY_AUDIO_INTERACTIVE=true
SPOTIFY_AUDIO_WORKERS=1
SPOTIFY_AUDIO_QUEUE=8
SPOTIFY_AUDIO_EMBED_TAGS=true
SPOTIFY_AUDIO_FORCE_MP3=false
SPOTIFY_AUDIO_FFMPEG_BIN=ffmpeg
SPOTIFY_AUDIO_EMBED_TEXT_LYRICS=true
SPOTIFY_AUDIO_LYRICS_LANG=eng
SPOTIFY_AUDIO_LYRICS_API=https://lrclib.net/api/get
AUDIO_FORMAT=mp3
AUDIO_QUALITY=320K
MEDIA_DOWNLOAD_MAX_MB=50
TELEGRAM_UPLOAD_MAX_MB=50
MEDIA_DOWNLOAD_MAX_HEIGHT=720
MEDIA_DOWNLOAD_INTERACTIVE=true
MEDIA_DOWNLOAD_WORKERS=1
MEDIA_DOWNLOAD_QUEUE=8
MEDIA_VIDEO_TRANSCODE_TIMEOUT_SEC=300
YTDLP_BIN=
YTDLP_EXTRACTOR_ARGS=youtube:player_client=android,web
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=
FIXIE_SOCKS_HOST=

# comma/space-separated numeric chat IDs.
# if empty, bot can work in any chat.
ALLOWED_CHAT_IDS=

# cache admin status lookups for this many seconds (reduces Telegram API calls)
ADMIN_CACHE_TTL_SEC=120
USER_INDEX_MAX=800
CHAT_RECENT_MAX_MESSAGES=8
CHAT_RECENT_MAX_AGE_SEC=1800
QS_HISTORY_MAX_MESSAGES=1000
QS_SESSION_TTL_SEC=3600
OLENYAM_CONTEXT_MESSAGES=4
CHAT_SUMMARY_EVERY_MESSAGES=200
CHAT_SUMMARY_POOL_MESSAGES=1000

# debug logs (can noticeably slow bot on busy chats if enabled)
DEBUG_TRIGGER_LOG=false
DEBUG_GPT_LOG=false
CHAT_ERROR_LOG=true
WEB_TEMPLATE_DIR=/home/faline/trigger_admin_bot/templates
WEB_STATIC_DIR=/home/faline/trigger_admin_bot/static
GPT_PROMPT_DEBOUNCE_SEC=10
GPT_REPLY_REACTION_CHANCE_PERCENT=50
GPT_MARKDOWN_DIVIDER_EMOJI=<tg-emoji emoji-id="5213083123218147891">〰️</tg-emoji>
BOT_COMMANDS_SYNC_ON_START=true
BOT_COMMANDS_SYNC_INTERVAL_MIN=0
BOT_COMMANDS_LANGS=ru

# web admin
ADMIN_ENABLED=true
ADMIN_BIND=:8090
ADMIN_TOKEN=
