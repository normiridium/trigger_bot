TELEGRAM_BOT_TOKEN=
PATH=/usr/local/go/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
# If set, MongoDB is used as primary storage backend.
# Example: mongodb://127.0.0.1:27017/trigger_admin_bot
MONGO_URI=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_WEB_SEARCH_MODEL=
OPENAI_ORIENTATION_MODEL=
AUDIO_TRANSCRIPTION_MODEL=
SERPAPI_KEY=
SERPAPI_ENGINE=google_images
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
YA_MUSIC_TOKEN=
YANDEX_MUSIC_QUALITY=1
YANDEX_MUSIC_TIMEOUT_SEC=45
YANDEX_MUSIC_TRIES=6
YANDEX_MUSIC_RETRY_DELAY_SEC=2
YANDEX_MUSIC_FORCE_MP3=true
YANDEX_MUSIC_EMBED_LYRICS=true
YANDEX_MUSIC_LYRICS_LANG=eng
YANDEX_MUSIC_FFMPEG_BIN=ffmpeg
YANDEX_MUSIC_WORKERS=1
YANDEX_MUSIC_QUEUE=4
# VK Music uses web cookies. Netscape cookies do not store User-Agent;
# VK_USER_AGENT is optional and can stay empty.
VK_COOKIES_FILE=
VK_USER_AGENT=
VK_PROXY_URL=
VK_WEB_USER_ID=
VK_AUDIO_INTERACTIVE=true
VK_AUDIO_MAX_MB=60
VK_AUDIO_FFMPEG_BIN=ffmpeg
VK_AUDIO_FFMPEG_TIMEOUT_SEC=120
VK_AUDIO_RETRY_COUNT=3
VK_AUDIO_RETRY_DELAY_MS=500
VK_AUDIO_WORKERS=1
VK_AUDIO_QUEUE=4
SPOTIFY_AUDIO_INTERACTIVE=true
SPOTIFY_AUDIO_WORKERS=1
SPOTIFY_AUDIO_QUEUE=8
SPOTIFY_AUDIO_EMBED_TAGS=true
SPOTIFY_AUDIO_FORCE_MP3=false
SPOTIFY_AUDIO_FFMPEG_BIN=ffmpeg
SPOTIFY_AUDIO_EMBED_TEXT_LYRICS=true
SPOTIFY_AUDIO_LYRICS_LANG=eng
SPOTIFY_AUDIO_LYRICS_API=https://lrclib.net/api/get
AUDIO_FORMAT=mp3
AUDIO_QUALITY=320K
MEDIA_DOWNLOAD_MAX_MB=50
TELEGRAM_UPLOAD_MAX_MB=50
MEDIA_DOWNLOAD_MAX_HEIGHT=720
MEDIA_VIDEO_MAX_DURATION_SEC=1800
